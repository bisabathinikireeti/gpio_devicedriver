#include <stdint.h>

/*
 * DMA2 + ADC1 - Onboard LM35 Temperature Sensor
 * Board  : Raayan Mini STM32F401RBT6
 * Pin    : PC0 = ADC1 Channel 10 (LM35 internally connected - User Manual §2.1.5)
 * Fix    : All variables declared at TOP of main() block - ARMCC V5 C90 mode
 */

/*************** RCC ******************/
#define RCC_AHB1ENR     (*(volatile uint32_t *)0x40023830)
#define RCC_APB2ENR     (*(volatile uint32_t *)0x40023844)

/*************** GPIOC ****************/
#define GPIOC_MODER     (*(volatile uint32_t *)0x40020800)

/*************** ADC1 *****************/
#define ADC1_CR2        (*(volatile uint32_t *)0x40012008)
#define ADC1_SMPR1      (*(volatile uint32_t *)0x4001200C)
#define ADC1_SQR3       (*(volatile uint32_t *)0x40012034)
#define ADC1_DR         (*(volatile uint32_t *)0x4001204C)

/*************** DMA2 *****************/
#define DMA2_LISR       (*(volatile uint32_t *)0x40026400)
#define DMA2_LIFCR      (*(volatile uint32_t *)0x40026408)
#define DMA2_S0CR       (*(volatile uint32_t *)0x40026410)
#define DMA2_S0NDTR     (*(volatile uint32_t *)0x40026414)
#define DMA2_S0PAR      (*(volatile uint32_t *)0x40026418)
#define DMA2_S0M0AR     (*(volatile uint32_t *)0x4002641C)
#define DMA2_S0FCR      (*(volatile uint32_t *)0x40026424)

/************* Buffer *****************/
#define BUF_LEN     1
uint16_t adc_buf[BUF_LEN] = {0};
uint32_t temperature       = 0;

int main(void)
{
    /* ALL variables declared at top - required for C90 (ARMCC V5) */
    uint32_t sum     = 0;
    uint32_t avg_adc = 0;
    uint8_t  i       = 0;

    /* ---------------------------------------------------------------
     * STEP 1: Enable Clocks
     * GPIOCEN = bit2  [RM §6.3.9,  p.118]
     * DMA2EN  = bit22 [RM §6.3.9,  p.118]
     * ADC1EN  = bit8  [RM §6.3.11, p.122]
     * --------------------------------------------------------------- */
    RCC_AHB1ENR |= (1<<2);
    RCC_AHB1ENR |= (1<<22);
    RCC_APB2ENR |= (1<<8);

    /* ---------------------------------------------------------------
     * STEP 2: PC0 = Analog mode
     * bits[1:0] = 11  [RM §8.4.1, p.148]
     * PC0 = ADC1_IN10 = LM35 output (User Manual §2.1.5, Schematic ADC Zone)
     * --------------------------------------------------------------- */
    GPIOC_MODER |= (3<<0);

    /* ---------------------------------------------------------------
     * STEP 3: Configure DMA2 Stream0
     * ADC1 --> DMA2, Stream0, Channel0  [RM Table 29, p.171]
     * --------------------------------------------------------------- */

    /* Disable Stream0 */
    DMA2_S0CR &= ~(1<<0);
    while(DMA2_S0CR & (1<<0));

    /* Clear all Stream0 flags - mask 0x3D [RM §9.5.3, p.190] */
    DMA2_LIFCR = 0x3D;

    /* Peripheral Address = ADC1_DR [RM §9.5.7] */
    DMA2_S0PAR = (uint32_t)&ADC1_DR;

    /* Memory Address = adc_buf [RM §9.5.8] */
    DMA2_S0M0AR = (uint32_t)adc_buf;

    /* Number of transfers [RM §9.5.6] */
    DMA2_S0NDTR = BUF_LEN;

    /* Clear CR */
    DMA2_S0CR = 0;

    /* Channel 0: CHSEL[2:0] bits[27:25] = 000 [RM §9.5.5, p.193] */
    DMA2_S0CR &= ~(7<<25);

    /* Direction = Peripheral to Memory: DIR[1:0] = 00 bits[7:6] */
    DMA2_S0CR &= ~(3<<6);

    /* Circular mode ON: CIRC bit8 = 1 [RM §9.3.8] */
    DMA2_S0CR |= (1<<8);

    /* Low Priority: PL[1:0] = 00 bits[17:16] */
    DMA2_S0CR &= ~(3<<16);

    /* Peripheral Size = 16-bit: PSIZE[1:0] = 01 bits[12:11] */
    DMA2_S0CR |= (1<<11);

    /* Memory Size = 16-bit: MSIZE[1:0] = 01 bits[14:13] */
    DMA2_S0CR |= (1<<13);

    /* Peripheral Increment OFF: PINC bit9 = 0 */
    DMA2_S0CR &= ~(1<<9);

    /* Memory Increment ON: MINC bit10 = 1 */
    DMA2_S0CR |= (1<<10);

    /* Direct Mode: FIFO disabled */
    DMA2_S0FCR = 0;

    /* Enable DMA2 Stream0 */
    DMA2_S0CR |= (1<<0);

    /* ---------------------------------------------------------------
     * STEP 4: Configure ADC1 - Channel 10 (PC0 = LM35)
     * --------------------------------------------------------------- */

    /* Sample time Channel 10: SMP10[2:0] bits[2:0] of SMPR1
     * (10-10)*3 = 0 --> bits[2:0]
     * 111 = 480 cycles  [RM §11.12.4, p.234] */
    ADC1_SMPR1 |= (7<<0);

    /* Sequence: Channel 10 first
     * SQ1[4:0] bits[4:0] = 10  [RM §11.12.11, p.237] */
    ADC1_SQR3 |= (10<<0);

    /* CR2: DMA=bit8, DDS=bit9, CONT=bit1, ADON=bit0 [RM §11.12.3] */
    ADC1_CR2 |= (1<<8);
    ADC1_CR2 |= (1<<9);
    ADC1_CR2 |= (1<<1);
    ADC1_CR2 |= (1<<0);

    /* ---------------------------------------------------------------
     * STEP 5: Start Conversion
     * SWSTART bit30  [RM §11.12.3, p.232]
     * --------------------------------------------------------------- */
    ADC1_CR2 |= (1<<30);

    /* ---------------------------------------------------------------
     * STEP 6: Wait for first buffer fill
     * TCIF0 = bit5 of LISR  [RM §9.5.1, p.188]
     * --------------------------------------------------------------- */
    while(!(DMA2_LISR & (1<<5)));

    /* Clear TC flag */
    DMA2_LIFCR = (1<<5);

    /* ---------------------------------------------------------------
     * STEP 7: Average 10 samples and calculate Temperature
     *
     * Temp(C) = ADC_avg x 330 / 4095
     * LM35 = 10mV per C, Vref = 3300mV, 12-bit ADC = 4095 max
     * --------------------------------------------------------------- */
    sum = 0;
    for(i = 0; i < BUF_LEN; i++)
    {
        sum += adc_buf[i];
    }
    avg_adc     = sum / BUF_LEN;
    temperature = (avg_adc * 330) / 4095;

    /*
     * Watch in Keil debugger:
     *   adc_buf[]   - raw 12-bit ADC values (0 to 4095)
     *   avg_adc     - averaged raw value
     *   temperature - degrees Celsius (integer)
     * At room temp ~25C: avg_adc ~ 310, temperature ~ 25
     */

    while(1);
}
