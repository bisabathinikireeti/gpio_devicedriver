#include<stdio.h>

void second_min(int arr[], int n)
{
    if(n < 2)
    {
        printf("Array should contain at least 2 elements");
        return;
    }

    int min1, min2;

    // Initialize
    if(arr[0] < arr[1])
    {
        min1 = arr[0];
        min2 = arr[1];
    }
    else if(arr[1] < arr[0])
    {
        min1 = arr[1];
        min2 = arr[0];
    }
    else
    {
        min1 = min2 = arr[0];
    }

    for(int i = 2; i < n; i++)
    {
        if(arr[i] < min1)
        {
            min2 = min1;
            min1 = arr[i];
        }
        else if(arr[i] < min2 && arr[i] != min1)
        {
            min2 = arr[i];
        }
    }

    // Check if second minimum exists
    if(min1 == min2)
    {
        printf("No second minimum number");
    }
    else
    {
        printf("\n%d is the second minimum number", min2);
    }
}

int main()
{
    int n;

    printf("Enter the number of elements:\n");
    scanf("%d", &n);

    int arr[n];

    printf("Enter array elements:\n");

    for(int i = 0; i < n; i++)
    {
        scanf("%d", &arr[i]);
    }

    second_min(arr, n);

    return 0;
}
